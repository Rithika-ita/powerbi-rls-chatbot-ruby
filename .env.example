# =============================================================================
# Power BI Configuration
# =============================================================================

# Azure AD / Entra ID - Service Principal
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Power BI Workspace & Report
PBI_WORKSPACE_ID=your-workspace-id
PBI_REPORT_ID=your-report-id
PBI_DATASET_ID=your-dataset-id

# RLS Role name configured in Power BI Desktop
PBI_RLS_ROLE=ViewerRole

# =============================================================================
# Azure OpenAI Configuration
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# =============================================================================
# App Configuration
# =============================================================================
APP_SECRET_KEY=change-me-to-a-random-secret

# Demo users (JSON map: display_name -> rls_username)
# These simulate unauthenticated users mapped to RLS identities
DEMO_USERS={"Alice (West Region)":"alice@contoso.com","Bob (East Region)":"bob@contoso.com","Carlos (All Regions)":"carlos@contoso.com"}
