# =============================================================================
# Power BI RLS Chatbot — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure AD / Entra ID — Service Principal
# Used for: embed token generation (client credentials flow)
# Setup: Register an app in Entra ID, create a client secret, and grant it
#        access to the Power BI workspace (Admin / Member / Contributor).
# -----------------------------------------------------------------------------
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# -----------------------------------------------------------------------------
# Power BI — Workspace, Report & Dataset
# Find these in the Power BI service URL or via REST API.
# -----------------------------------------------------------------------------
PBI_WORKSPACE_ID=your-workspace-id
PBI_REPORT_ID=your-report-id
PBI_DATASET_ID=your-dataset-id

# The RLS role name defined in Power BI Desktop (case-sensitive).
# This role is applied when generating embed tokens with effective identity.
PBI_RLS_ROLE=ViewerRole

# -----------------------------------------------------------------------------
# DAX Execution — Authentication Mode
# The executeQueries API requires a delegated (user-context) token.
# Service Principals and Managed Identities use client-credentials flow,
# which does NOT provide a user context — they will get HTTP 401.
#
# Supported modes:
#   azcli  — (default) Uses your `az login` session. Dev/testing only.
#   ropc   — Resource Owner Password Credential ("Master User").
#            Stores a service account's email + password to get a delegated
#            token. The account must NOT have MFA enabled.
#            Requires: DAX_USER_EMAIL, DAX_USER_PASSWORD
#            The app registration must allow public client flows
#            (Portal → App Registration → Authentication → Advanced
#             → Allow public client flows → Yes).
# -----------------------------------------------------------------------------
DAX_AUTH_MODE=azcli

# Only needed when DAX_AUTH_MODE=ropc
# DAX_USER_EMAIL=admin@yourtenant.onmicrosoft.com
# DAX_USER_PASSWORD=your-password

# -----------------------------------------------------------------------------
# LLM/AI Configuration — Choose One
# Either use Azure OpenAI (default) OR Fabric Data Agent (recommended for Fabric)
# If both are configured, Fabric Data Agent takes precedence.
# -----------------------------------------------------------------------------

# --- Option 1: Azure OpenAI (traditional approach) ---
# Used for: natural language → DAX generation and result summarisation.
# Auth: Uses DefaultAzureCredential (az login locally, Managed Identity in
#       Azure). The identity needs "Cognitive Services OpenAI User" role on
#       the Azure OpenAI resource.
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Option 2: Microsoft Fabric Data Agent (recommended for Fabric workspaces) ---
# Used for: natural language → DAX generation, execution, and response generation.
# Auth: Uses azcli (az login) or ROPC credentials for authentication.
# The Data Agent handles the entire NL → DAX → results → answer flow.
# 
# To enable:
#   1. Set USE_FABRIC_DATA_AGENT=true
#   2. Set FABRIC_DATA_AGENT_URL to your Data Agent endpoint
#   3. Ensure your Data Agent is deployed in your Fabric workspace
#
# Published URL format:
#   https://api.fabric.microsoft.com/v1/workspaces/{workspace-id}/dataagents/{agent-id}/aiassistant/openai
#
USE_FABRIC_DATA_AGENT=false
FABRIC_DATA_AGENT_URL=https://api.fabric.microsoft.com/v1/workspaces/YOUR_WORKSPACE_ID/dataagents/YOUR_AGENT_ID/aiassistant/openai

# Replace YOUR_WORKSPACE_ID and YOUR_AGENT_ID with your actual IDs.
# You can find these in the Fabric portal when you publish your Data Agent.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_SECRET_KEY=change-me-to-a-random-string

# Demo users — JSON map of display name → RLS username (UPN).
# These appear in the user-switcher dropdown to simulate different identities.
# In production, replace with real AAD authentication.
DEMO_USERS={"Alice (West)":"alice@contoso.com","Bob (East)":"bob@contoso.com"}
