# Power BI RLS Chatbot (Ruby) - Environment Configuration
# Copy this file to .env and fill all required values.

# Azure Entra app registration used for embed token generation.
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Power BI report/model settings.
PBI_WORKSPACE_ID=your-workspace-id
PBI_REPORT_ID=your-report-id
PBI_DATASET_ID=your-dataset-id
PBI_RLS_ROLE=ViewerRole

# DAX execution authentication mode:
# - default_credential: uses Azure CLI token in this Ruby app (run: az login)
# - master_user: delegated token via DAX_USER_EMAIL + DAX_USER_PASSWORD (no MFA)
DAX_AUTH_MODE=default_credential
# DAX_USER_EMAIL=service-account@contoso.com
# DAX_USER_PASSWORD=replace-me

# Azure OpenAI settings for DAX generation and summarization.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Optional when using Azure CLI bearer token fallback:
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MAX_TOKENS=900
SUMMARY_ROW_LIMIT=50

# App settings.
APP_SECRET_KEY=replace-with-random-value
DEMO_USERS={"Alice (West)":"alice@contoso.com","Bob (East)":"bob@contoso.com"}
