# =============================================================================
# Power BI RLS Chatbot — Environment Configuration (Foundry + Client Credentials)
# Copy this file to .env and fill in your values.
# 
# This application uses Azure AI Foundry with client credentials authentication.
# The service principal authenticates to Foundry directly (no user sign-in needed
# for chat). RLS context is passed in the conversation prompt.
# =============================================================================

# =============================================================================
# SECTION 1: Azure Entra ID (Service Principal)
# =============================================================================
# 
# These credentials are used for:
#   1. Client credentials flow to acquire a Foundry token
#   2. Service Principal for Power BI embedding (generate embed tokens)
#
# Setup in Entra:
#   1. Create an Entra app registration (single tenant)
#   2. Create a Client Secret
#   3. Grant Power BI API permissions: Dataset.Read.All, Item.Execute.All
#   4. Grant admin consent
#
# Setup in Azure AI resource (IAM):
#   1. Go to your Azure AI resource → Access Control (IAM)
#   2. Add role assignment: "Cognitive Services User"
#   3. Assign to your app registration's service principal

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# =============================================================================
# SECTION 2: Power BI Workspace & Report (for Embed Tokens + Schema)
# =============================================================================

PBI_WORKSPACE_ID=your-workspace-id
PBI_REPORT_ID=your-report-id
PBI_DATASET_ID=your-dataset-id

# RLS role name defined in Power BI Desktop (case-sensitive)
# This role is applied to embed tokens with effective identity
PBI_RLS_ROLE=ViewerRole

# =============================================================================
# SECTION 3: DAX Execution — Authentication Mode
# =============================================================================
# 
# The Power BI executeQueries API requires a delegated (user-context) token.
# Service Principals cannot be used directly for DAX execution.
#
# Supported modes:
#   azcli  — (default) Uses your local `az login` session. Development only.
#   ropc   — Resource Owner Password Credential ("Service Account").
#            Provide a dedicated service account's email + password
#            (MFA must be disabled on the account).
#            App registration must allow public client flows.
#
# NOTE: With Foundry, DAX execution is handled by Foundry itself.
# These settings are used only for the /api/embed-token endpoint if it
# needs to refresh the Power BI schema. Optional if your schema is static.

DAX_AUTH_MODE=azcli
# DAX_USER_EMAIL=admin@yourtenant.onmicrosoft.com
# DAX_USER_PASSWORD=your-password

# =============================================================================
# SECTION 4: Azure AI Foundry Configuration (PRIMARY PATH)
# =============================================================================
#
# Azure AI Foundry acts as the orchestration layer that:
#   1. Accepts user messages and conversation history
#   2. Connects to your Fabric Data Agent or Direct Query endpoint
#   3. Returns natural language answers with RLS-filtered data
#
# Authentication:
#   - Backend acquires a Foundry token using client credentials
#     (scope: https://ai.azure.com/.default)
#   - No user sign-in or OBO required
#   - RLS context is injected as a system message in the conversation
#
# Azure AI resource IAM setup:
#   1. Go to Azure Portal → your Azure AI resource → Access Control (IAM)
#   2. Click "Add role assignment"
#   3. Role: "Cognitive Services User"
#   4. Assign to: your app registration service principal
#   5. Save
#
# Find FOUNDRY_ENDPOINT:
#   1. Go to Azure AI Foundry → your project
#   2. Go to Deployments → your deployment
#   3. Copy the endpoint URL
#   4. Use only the project base endpoint (WITHOUT /openai/v1/chat/completions)
#      Example: https://<resource>.services.ai.azure.com/api/projects/<project>
#
# Find FOUNDRY_MODEL:
#   1. Go to Azure AI Foundry → your project → Deployments
#   2. Copy the deployment name (not the model family label)
#
# FOUNDRY_AGENT_ID:
#   1. Go to Azure AI Foundry → your project → "Create and debug your agents"
#   2. Click on your agent (e.g., "Fabric Agent")
#   3. Copy the ID from the agent details (format: asst_...)
#   4. This ensures the agent uses its attached knowledge source
#      (e.g., fabric-analytics-dataagent)

FOUNDRY_ENDPOINT=https://your-foundry.services.ai.azure.com/api/projects/your-project
FOUNDRY_MODEL=your-deployment-name
FOUNDRY_AGENT_ID=asst_your-agent-id
FOUNDRY_SCOPE=https://ai.azure.com/.default
# How to pass user context to the Foundry agent:
#   plain (default)  -> natural language context only
#   off              -> send no extra user context
#   raw              -> append literal table[column] = 'value' text
FOUNDRY_RLS_CONTEXT_MODE=plain
# Thread behavior:
#   false (default) -> create a fresh thread per request (closest to playground)
#   true            -> reuse per-user in-memory thread across requests
FOUNDRY_REUSE_THREADS=false

# =============================================================================
# SECTION 5: Application Settings
# =============================================================================

APP_SECRET_KEY=change-me-to-a-random-string

# Demo users for testing (JSON map of display_name → RLS username/UPN)
# These populate the user-switcher dropdown
DEMO_USERS={"Alice (West)":"alice@contoso.com","Bob (East)":"bob@contoso.com"}
